# ─────────────────────────────────────────────────────
# FoodRush Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# MySQL (RDS)
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_USER=foodapp
DB_PASS=YourStrongPasswordHere
DB_NAME=foodapp

# S3
S3_BUCKET=foodapp-images-ACCOUNT_ID
AWS_REGION=ap-south-1
